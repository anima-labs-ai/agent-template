# Anima API key — get yours at https://useanima.sh
ANIMA_API_KEY=

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Your Anima organization ID
ANIMA_ORG_ID=

# Agent display name (used to create/find your agent)
AGENT_NAME=my-agent

# Webhook server port
PORT=5000

# Optional: webhook signing secret for signature verification
WEBHOOK_SECRET=

# Optional: customize the AI personality
# SYSTEM_PROMPT=You are a helpful AI assistant that responds to emails.
